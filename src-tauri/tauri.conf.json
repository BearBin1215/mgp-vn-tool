{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mgp-vn-tool",
  "version": "0.3.3",
  "identifier": "com.bearbin.mgp-vn-tool",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "萌百视研会条目工具",
        "width": 1440,
        "height": 810,
        "minWidth": 720,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*.jpg",
          "**/*.jpeg",
          "**/*.png",
          "**/*.gif",
          "**/*.webp",
          "**/*.bmp",
          "**/*.JPG",
          "**/*.JPEG",
          "**/*.PNG",
          "**/*.GIF",
          "**/*.WEBP",
          "**/*.BMP"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
